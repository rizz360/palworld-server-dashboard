{
  "name": "palworld-server-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-based dashboard for Palworld server monitoring, moderation, and live operations.",
  "license": "MIT",
  "engines": {
    "node": "24.18.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node scripts/build-search-index.mjs",
    "start": "next start",
    "postinstall": "node scripts/patch-nextra-theme-docs.mjs",
    "typegen": "node -e \"require('node:fs').rmSync('.next', { recursive: true, force: true })\" && next typegen",
    "lint": "npm run typecheck",
    "typecheck": "npm run typegen && tsc --noEmit",
    "check": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@vercel/analytics": "1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.564.0",
    "next": "^16.2.0",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.3.1"
  },
  "knip": {
    "ignore": [
      "content/**/_meta.js"
    ]
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^22",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "knip": "^6.26.0",
    "pagefind": "^1.5.2",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "1.3.3",
    "typescript": "5.7.3"
  }
}
