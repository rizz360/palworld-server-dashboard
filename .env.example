# ─── Required: panel login ───────────────────────────────────────────────────
# Seeds the panel credential store on first run only. After that, change
# passwords from the dashboard Settings dialog. Use strong, unique values.
PANEL_INITIAL_ADMIN_PASSWORD=change-me-admin

# Optional initial moderator password. Leave empty to disable the mod tier.
PANEL_INITIAL_MOD_PASSWORD=

# Persistent writable file for panel password hashes.
PANEL_AUTH_FILE=./data/panel-auth.json


# ─── Required: Palworld REST API ─────────────────────────────────────────────
# Server-side URL of the Palworld REST API. In Docker, 127.0.0.1 is the
# container; use host.docker.internal:8212 or the game host LAN IP.
PALWORLD_REST_URL=http://127.0.0.1:8212

# Real Palworld REST/Admin password from PalWorldSettings.ini.
# Injected server-side only; never sent to the browser.
PALWORLD_ADMIN_PASSWORD=your-real-palworld-admin-password
# PALWORLD_REAL_ADMIN_PASSWORD is also accepted as an alias.


# ─── Optional: public demo ───────────────────────────────────────────────────
# Serves mock data instead of contacting a real Palworld server.
# Enable only with DEMO_MODE=1.
# DEMO_MODE=1


# ─── Optional: public read-only status page ──────────────────────────────────
# Serves /view (metrics + live map + player names/levels) and its data source
# /api/public-view WITHOUT a panel password. Off by default. The payload is
# allowlisted server-side: no player IPs, no Steam/user IDs, no ping, no
# settings. Note that player names and live positions ARE shown publicly —
# make sure your community is fine with that before enabling.
# PUBLIC_VIEW_ENABLED=true

# Server-side cache for the public snapshot, clamped 5-60 seconds. All public
# traffic shares one cached upstream read per window.
# PUBLIC_VIEW_CACHE_SECONDS=10

# Replace real player names on /view with stable pseudonyms ("Player-3f2a").
# Positions and levels stay visible, but who is who does not. Pseudonyms are
# consistent while the dashboard runs and rotate on restart.
# PUBLIC_VIEW_ANONYMIZE_NAMES=true


# ─── Optional: network/security ──────────────────────────────────────────────
# Trust x-real-ip / x-forwarded-for only behind a reverse proxy you control.
# RATE_LIMIT_TRUST_PROXY=false


# ─── Optional: dashboard UI ──────────────────────────────────────────────────
# Prefix for announcements sent from the web chat console.
# NEXT_PUBLIC_CHAT_SENDER_PREFIX="[Admin] "

# Snapshot poll interval in seconds, clamped 5-120.
# Build-time only; changing this has no effect on prebuilt images.
# NEXT_PUBLIC_SNAPSHOT_POLL_SECONDS=15

# Comma-separated exact userIds hidden from the MOD widget only.
# Admin roster still shows everyone.
# NEXT_PUBLIC_MOD_WIDGET_HIDDEN_USERIDS=steam_00000000000000000


# ─── Optional: live chat logs ────────────────────────────────────────────────
# The live-chat console reads player chat from the game server's stdout log.
# It has no REST endpoint, so pick ONE source below (checked in this order):
#
# 1. A log file — no systemd, no Docker socket. Best for Kubernetes/containerd
#    (Talos) and Podman: point this at a file fed the game's stdout (a relay
#    sidecar, a read-only hostPath of /var/log/pods, `docker logs -f >> file`,
#    a shared volume, ...). Accepts a glob (newest match wins) and auto-strips
#    the Kubernetes/CRI line prefix.
# PALWORLD_CHAT_LOG_FILE=/gamelog/palworld.log
#
# 2. docker logs — reads `docker logs <container>`. Requires the Docker socket
#    (and CLI) mounted into the dashboard container.
# PALWORLD_DOCKER_CONTAINER=palworld
#
# 3. journalctl (default) — reads the systemd unit's journal. Requires Linux +
#    systemd and journal read access for the app user (systemd-journal group).
# PALWORLD_SYSTEMD_UNIT=palworld


# ─── Optional: server restart integration ───────────────────────────────────
# Request-flag path for the optional host-driven restart feature.
# PALWORLD_RESTART_REQUEST_PATH=/run/palworld/restart.request


# ─── Optional: server-side FPS history ───────────────────────────────────────
# In-process sampler: when enabled, the dashboard itself polls the game's
# /v1/api/metrics and maintains the FPS history ring (this replaced the former
# sampler sidecar/systemd service). When unset, the sampler code is never even
# loaded and the panel only reads the ring file if something else maintains it.
# PALWORLD_FPS_SAMPLER=true

# Ring file the sampler writes and the dashboard reads — one variable for both
# ends. Keep it on persisted, dashboard-writable storage so history survives
# restarts (Docker Compose points it into the /app/data volume automatically).
# PALWORLD_FPS_HISTORY_FILE=./data/fps-history.json

# The sampler stamps FPS_WINDOW_MINUTES into the ring file, and the dashboard
# reads it back — so raising it both retains more history AND widens the window
# the panel charts. Clamped 5-1440 min; FPS_SAMPLE_SECONDS is the poll cadence
# (clamped 1-60 s).
# FPS_SAMPLE_SECONDS=5
# FPS_WINDOW_MINUTES=60
