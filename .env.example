# ─── Panel login credentials (server-side only, never sent to the browser) ────
# The browser only ever submits ONE password. The server hashes it (scrypt) and
# resolves it to a tier; for a valid panel password it swaps in the real game
# admin credential (below) before calling the Palworld REST API.
#
# On first run the panel SEEDS its credential store from the two variables below
# and writes scrypt hashes to PANEL_AUTH_FILE. After that you change the
# passwords from the panel's own Settings dialog — the INITIAL_* vars are only a
# bootstrap. Use strong, unique values; these are placeholders.
PANEL_INITIAL_ADMIN_PASSWORD=change-me-admin

# Optional: enables the limited MOD tier (kick / ban / roster only, enforced by a
# server-side endpoint allowlist). Leave unset/empty to keep the mod tier off.
PANEL_INITIAL_MOD_PASSWORD=

# Where the panel writes its own credential hashes (created on first run). Must be
# writable by the app's user and should live on a persistent volume.
PANEL_AUTH_FILE=./data/panel-auth.json

# ─── Game server REST target ─────────────────────────────────────────────────
# The panel proxies all Palworld REST calls to this PINNED, server-side URL. It is
# never client-controllable, so the panel can be exposed without letting a browser
# reach arbitrary internal hosts. NOTE: inside Docker, 127.0.0.1 is the container,
# not the host — use host.docker.internal:8212 or the game host's LAN IP.
PALWORLD_REST_URL=http://127.0.0.1:8212

# The real Palworld REST/Admin password the game expects (`AdminPassword` in
# PalWorldSettings.ini, with `RESTAPIEnabled=True`). Injected into upstream REST
# calls by the proxy; never reaches the browser.
# (PALWORLD_REAL_ADMIN_PASSWORD is an accepted alias.)
PALWORLD_ADMIN_PASSWORD=your-real-palworld-admin-password

# ─── Optional ────────────────────────────────────────────────────────────────
# Trust reverse-proxy client-IP headers (x-real-ip / x-forwarded-for) for the
# brute-force limiter. Keep false unless the panel sits behind a reverse proxy YOU
# control that overwrites these headers — a directly exposed panel must leave this
# false, or the limiter can be bypassed with a spoofed header.
# RATE_LIMIT_TRUST_PROXY=false

# systemd unit the live-chat console tails via journalctl (default: palworld).
# Requires Linux + systemd and the panel's OS user in the systemd-journal group.
# PALWORLD_SYSTEMD_UNIT=palworld

# Prefix applied to announcements sent from the web chat console (default: [Admin]).
# NEXT_PUBLIC_CHAT_SENDER_PREFIX="[Admin] "

# How often (seconds, 5-120) an open panel fetches its combined snapshot
# (metrics + players + FPS history in ONE request). BUILD-time only — inlined
# by `next build`, so it has no effect on prebuilt images. Default 15.
# NEXT_PUBLIC_SNAPSHOT_POLL_SECONDS=15

# Comma-separated exact userIds hidden from the MOD widget only (empty by default).
# The full admin roster always shows everyone.
# NEXT_PUBLIC_MOD_WIDGET_HIDDEN_USERIDS=steam_00000000000000000

# Request-flag path for the optional host-driven restart feature (see the
# "Optional: server restart" section of the README).
# PALWORLD_RESTART_REQUEST_PATH=/run/palworld/restart.request

# ─── Server-side FPS history (sampler + panel) ───────────────────────────────
# The FPS histogram is fed by a small server-side sampler (scripts/fps-sampler/)
# that polls the game's /metrics endpoint and maintains a rolling ring file —
# so the history stays populated even while nobody has the panel open, and
# server downtime shows as an honest gap. docker-compose runs it as a sidecar
# automatically; bare-metal installs can use the systemd example unit.
#
# Where the PANEL reads the ring from (must match the sampler's output path;
# the compose file wires both to a shared volume automatically):
# PALWORLD_FPS_HISTORY_FILE=/run/palworld-metrics/fps-history.json

# Sampler poll cadence in seconds (1-60) and window in minutes (5-1440).
# The dashboard's chart is designed around the 5s/60min defaults.
# FPS_SAMPLE_SECONDS=5
# FPS_WINDOW_MINUTES=60
